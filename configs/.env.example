# ========== General ==========
APP_ENV=development       # development | production
APP_PORT=8000

# ========== LangChain / LangGraph ==========
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=your-langsmith-key
LANGCHAIN_PROJECT="rag-practice-mvp"

# ========== Vector Database (Qdrant) ==========
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=your-qdrant-api-key   # leave empty if running local without auth
QDRANT_COLLECTION=rag_documents

# ========== External LLM Providers ==========
# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Google (Gemini / Palm)
GOOGLE_API_KEY=your-google-api-key
GOOGLE_MODEL=gemini-pro

# Local LLM (Ollama / HuggingFace)
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_MODEL=llama3
LOCAL_LLM_ENDPOINT=http://localhost:11434

# ========== AWS / GCP (deployment later) ==========
# AWS
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=rag-mvp-bucket

# GCP
GCP_PROJECT_ID=your-gcp-project
GCP_SERVICE_ACCOUNT_KEY=path/to/gcp-key.json
GCP_BUCKET=rag-mvp-bucket

# ========== Misc ==========
MAX_CHUNK_SIZE=1000
EMBEDDING_MODEL=text-embedding-3-large
TOP_K=5

# ========== Logging ==========
LOG_LEVEL=INFO
LOG_PATH=./logs
LOG_ROTATION=D
LOG_RETENTION=7
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(filename)s:%(lineno)d - %(funcName)s() - %(message)s
LOG_DATE_FORMAT=%d-%m-%Y %H:%M:%S